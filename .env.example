# Copy this file to .env and add your values.
#   cp .env.example .env
#
# Backend API (driver-garage-backend must be running, e.g. npm run dev)
# - Android emulator: use 10.0.2.2 (not localhost) to reach your machine
#   API_BASE_URL=http://10.0.2.2:4000
# - iOS simulator: localhost usually works
#   API_BASE_URL=http://localhost:4000
# - Physical device: use your computer's IP on the same Wi‑Fi (e.g. 192.168.1.5)
#   API_BASE_URL=http://192.168.1.5:4000
API_BASE_URL=http://10.0.2.2:4000
#
# Google Maps - get a key at https://console.cloud.google.com/
# Enable: Places API, Geocoding API, Maps SDK for Android, Maps SDK for iOS.
# Do not commit .env; the app reads this key from .env only (no keys in repo).
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
